{{page-title "Env File Maker"}}
<div class="tribe-manual">
  <ManualHeader />

  <ManualPageNav @activePage="backend" />

  <div class="container py-5">

    <div class="mb-4">
      <h4 class="mb-1"><i class="fa-solid fa-file-code me-2"></i>Env File Maker</h4>
      <p class="text-muted mb-0 small">Fill in the fields and generate a ready-to-use <code>.env</code> file.</p>
    </div>

    {{! ── Target selector ── }}
    <div class="mb-4">
      <div class="btn-group" role="group">
        {{#each this.targets as |target|}}
          <button
            type="button"
            class="btn {{if (eq this.activeTarget target) 'btn-dark' 'btn-outline-dark'}}"
            {{on "click" (fn this.selectTarget target)}}
          >
            {{target}}
          </button>
        {{/each}}
      </div>
    </div>

    {{! ── Fields ── }}
    <div class="card mb-4">
      <div class="card-body">
        <div class="row g-3">
          {{#if this.hasPorts}}
            <div class="col-md-6">
              <label class="form-label small fw-semibold mb-1" for="field-port-prefix">
                Port Prefix
                <span class="text-muted fw-normal">— Ports</span>
              </label>
              <input
                id="field-port-prefix"
                type="text"
                class="form-control form-control-sm"
                placeholder="120"
                value={{this.portPrefix}}
                {{on "input" this.updatePortPrefix}}
              />
              <div class="form-text text-muted">
                <code>120</code> → <code>12000</code>, <code>12001</code> … <code>12008</code>
              </div>
            </div>
          {{/if}}

          {{#each this.visibleFields as |field|}}
            <div class="col-md-6">
              <label class="form-label small fw-semibold mb-1" for="field-{{field.key}}">
                {{field.label}}
                {{#if field.comment}}
                  <span class="text-muted fw-normal">— {{field.comment}}</span>
                {{/if}}
              </label>
              <input
                id="field-{{field.key}}"
                type="text"
                class="form-control form-control-sm"
                placeholder={{field.placeholder}}
                value={{get this.values field.key}}
                {{on "input" (fn this.updateValue field.key)}}
              />
              <div class="form-text"><code>{{field.key}}</code></div>
            </div>
          {{/each}}
        </div>

        <div class="mt-4">
          <button type="button" class="btn btn-dark" {{on "click" this.generate}}>
            <i class="fa-solid fa-wand-magic-sparkles me-2"></i>Generate .env
          </button>
        </div>
      </div>
    </div>

    {{! ── Output ── }}
    {{#if this.generated}}
      <div class="card">
        <div class="card-body">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <h6 class="mb-0"><i class="fa-solid fa-file-lines me-2"></i>.env output</h6>
            <button type="button" class="btn btn-sm btn-outline-dark" {{on "click" this.copyOutput}}>
              <i class="fa-regular fa-copy me-1"></i>Copy
            </button>
          </div>
          <pre class="mb-0 p-3 bg-light rounded small">{{this.generated}}</pre>
        </div>
      </div>
    {{/if}}

  </div>
</div>
