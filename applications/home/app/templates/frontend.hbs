<div class="tribe-manual">
  <ManualHeader />

  <ManualPageNav @activePage="frontend" />

  <div class="container pb-5">

    <div class="steps-container mb-5">

      <div
        class="step-card"
        data-step-name="Install from Template tribe git template frontend"
      >
        <div class="step-header" onclick="toggleStep(this)">
          <span class="step-badge">1</span>
          <span class="step-title">Install from Template</span>
          <i class="fa-solid fa-chevron-down step-chevron"></i>
        </div>
        <div class="step-body">
          <p>Use the tribe-framework Git template for your frontend application.</p>
          <div class="text-center my-3">
            <a
              href="https://github.com/new?template_name=tribe&template_owner=tribe-framework"
              target="_blank"
              class="btn btn-info btn-lg me-2"
              rel="noopener noreferrer"
            >
              Use the Git Template
            </a>
            <a
              href="https://github.com/tribe-framework/tribe"
              target="_blank"
              class="btn btn-outline-dark btn-lg"
              rel="noopener noreferrer"
            >
              View on GitHub
            </a>
          </div>
        </div>
      </div>

      <div
        class="step-card"
        data-step-name="Open Command Line navigate directory terminal cd"
      >
        <div class="step-header" onclick="toggleStep(this)">
          <span class="step-badge">2</span>
          <span class="step-title">Open Command Line (Tribe folder)</span>
          <i class="fa-solid fa-chevron-down step-chevron"></i>
        </div>
        <div class="step-body">
          <p>Open your terminal and navigate to the directory that has been
            cloned from the template:</p>
          <div class="command-block">
            <button
              class="btn btn-sm copy-btn-block"
              onclick="copyCmd('cd /path/to/frontend/directory', this)"
              type="button"
            >Copy</button>
            <code><span class="comment"># Navigate to your Tribe directory</span><br
              />cd /path/to/tribe/directory</code>
          </div>
        </div>
      </div>

      <div
        class="step-card"
        data-step-name="Install EmberJS in project ember-init script setup"
      >
        <div class="step-header" onclick="toggleStep(this)">
          <span class="step-badge">3</span>
          <span class="step-title">Install EmberJS in Project</span>
          <i class="fa-solid fa-chevron-down step-chevron"></i>
        </div>
        <div class="step-body">
          <p>Run the initialization script to set up EmberJS within your
            project. You'll be prompted to enter the name of your application
            directory.</p>

          <div class="row g-3">
            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6><strong>Linux &amp; macOS:</strong></h6>
                  <div class="command-block mb-0">
                    <button
                      class="btn btn-sm copy-btn-block"
                      onclick="copyCmd('chmod +x ./config/ember/ember-init.sh; bash ./config/ember/ember-init.sh;', this)"
                      type="button"
                    >Copy</button>
                    <code>chmod +x ./config/ember/ember-init.sh; bash
                      ./config/ember/ember-init.sh;</code>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6><strong>Windows:</strong></h6>
                  <div class="command-block mb-0">
                    <button
                      class="btn btn-sm copy-btn-block"
                      onclick="copyCmd('powershell -ExecutionPolicy Bypass -File .\\config\\ember\\ember-init.ps1', this)"
                      type="button"
                    >Copy</button>
                    <code>powershell -ExecutionPolicy Bypass -File
                      .\config\ember\ember-init.ps1</code>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="alert alert-info mt-3 mb-0">
            <strong>Note:</strong>
            When prompted, enter the name of your EmberJS application directory.
          </div>
        </div>
      </div>

      <div
        class="step-card"
        data-step-name="Open Command Line navigate directory terminal cd"
      >
        <div class="step-header" onclick="toggleStep(this)">
          <span class="step-badge">4</span>
          <span class="step-title">Open Command Line (Ember application)</span>
          <i class="fa-solid fa-chevron-down step-chevron"></i>
        </div>
        <div class="step-body">
          <p>Open your terminal and navigate to the Ember directory that got
            created:</p>
          <div class="command-block">
            <button
              class="btn btn-sm copy-btn-block"
              onclick="copyCmd('cd applications/home', this)"
              type="button"
            >Copy</button>
            <code><span class="comment"># Navigate to your Ember application
                directory</span><br />cd /path/to/applications/ember/directory</code>
          </div>
        </div>
      </div>

      <div
        class="step-card"
        data-step-name="Start Development Server ember serve localhost 4200 hot-reload"
      >
        <div class="step-header" onclick="toggleStep(this)">
          <span class="step-badge">5</span>
          <span class="step-title">Start Development (Serve)</span>
          <i class="fa-solid fa-chevron-down step-chevron"></i>
        </div>
        <div class="step-body">
          <p>Serve the EmberJS application to start coding:</p>

          <div class="command-block">
            <button
              class="btn btn-sm copy-btn-block"
              onclick="copyCmd('ember s', this)"
              type="button"
            >Copy</button>
            <code>ember s</code>
          </div>

          <div class="alert alert-success mt-3">
            <h6 class="alert-heading mb-1">EmberJS Development Server:</h6>
            <p class="mb-0">Your frontend will be available at:
              <a
                href="http://localhost:4200"
                target="_blank"
                class="fw-bold"
                rel="noopener noreferrer"
              >localhost:4200</a></p>
          </div>

          <div class="alert alert-info mb-0">
            <strong>Tip:</strong>
            The development server includes hot-reload functionality. Changes to
            your code will automatically refresh in the browser.
          </div>
        </div>
      </div>

      <div
        class="step-card"
        data-step-name="Build for Production ember build dist deploy"
      >
        <div class="step-header" onclick="toggleStep(this)">
          <span class="step-badge">6</span>
          <span class="step-title">Build for Production</span>
          <i class="fa-solid fa-chevron-down step-chevron"></i>
        </div>
        <div class="step-body">
          <p>When you're ready to deploy, build your application for production:</p>
          <div class="command-block">
            <button
              class="btn btn-sm copy-btn-block"
              onclick="copyCmd('ember build -prod', this)"
              type="button"
            >Copy</button>
            <code>ember build -prod</code>
          </div>
          <div class="alert alert-success mt-3 mb-0">
            <h6 class="alert-heading mb-1">Build Output:</h6>
            <p class="mb-0">The production-ready build will be generated in the
              <code>dist/</code>
              directory.</p>
          </div>
        </div>
      </div>

      <div
        class="step-card"
        data-step-name="Deploy to Production Netlify Cloudflare hosting"
      >
        <div class="step-header" onclick="toggleStep(this)">
          <span class="step-badge">7</span>
          <span class="step-title">Deploy to Production</span>
          <i class="fa-solid fa-chevron-down step-chevron"></i>
        </div>
        <div class="step-body">
          <p>Deploy your built application to your preferred hosting platform:</p>
          <div class="row g-3">
            <div class="col-md-4">
              <div class="card h-100">
                <div class="card-body text-center">
                  <h5 class="card-title">Netlify</h5>
                  <p class="card-text small">Easy deployment with continuous
                    integration</p>
                  <a
                    href="https://www.netlify.com"
                    target="_blank"
                    class="btn btn-outline-dark"
                    rel="noopener noreferrer"
                  >Deploy to Netlify</a>
                </div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="card h-100">
                <div class="card-body text-center">
                  <h5 class="card-title">Cloudflare Pages</h5>
                  <p class="card-text small">Fast, secure deployment with global
                    CDN</p>
                  <a
                    href="https://pages.cloudflare.com"
                    target="_blank"
                    class="btn btn-outline-dark"
                    rel="noopener noreferrer"
                  >Deploy to Cloudflare</a>
                </div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="card h-100">
                <div class="card-body text-center">
                  <h5 class="card-title">Junction</h5>
                  <p class="card-text small">Junction has a built-in
                    <code>dist</code>
                    drop tool which you can access from the 3 dots menu on the
                    top right corner, via menu item
                    <strong>Dist Uploads.</strong></p>
                </div>
              </div>
            </div>
          </div>
          <div class="alert alert-info mt-3 mb-0">
            <strong>Deployment tip:</strong>
            All three platforms support drag-and-drop deployment of your
            <code>dist/</code>
            folder.
          </div>
        </div>
      </div>

      <div
        class="step-card"
        data-step-name="PHP Middleware dist-php ember-tribe server-side"
      >
        <div class="step-header" onclick="toggleStep(this)">
          <span class="step-badge">8</span>
          <span class="step-title">PHP Middleware (dist-php)</span>
          <i class="fa-solid fa-chevron-down step-chevron"></i>
        </div>
        <div class="step-body">
          <p>ember-tribe includes
            <strong>php-dist</strong>, a script that converts your production
            build into a PHP-aware entry point. Run it after
            <code>ember build -prod</code>:</p>
          <div class="command-block mb-3">
            <button
              class="btn btn-sm copy-btn-block"
              onclick="copyCmd('node php-dist', this)"
              type="button"
            >Copy</button>
            <code>node php-dist</code>
          </div>
          <p>It reads
            <code>dist/index.html</code>
            and writes
            <code>dist/index.php</code>
            with the following transformations:</p>
          <div class="row g-3">
            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6><strong>What it injects</strong></h6>
                  <ul class="mb-0 small">
                    <li>Prepends <code>_init.php</code> at the very top</li>
                    <li>Injects
                      <code>_head.php</code>
                      before
                      <code>&lt;title&gt;</code></li>
                    <li>Injects
                      <code>_head_footer.php</code>
                      before
                      <code>&lt;/head&gt;</code></li>
                    <li>Injects
                      <code>_body_footer.php</code>
                      before
                      <code>&lt;/body&gt;</code></li>
                  </ul>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6><strong>What it strips</strong></h6>
                  <ul class="mb-0 small">
                    <li>Removes
                      <code>&lt;title&gt;</code>
                      (let PHP control it per-page)</li>
                    <li>Removes
                      <code>&lt;meta name="description"&gt;</code>
                      (same reason)</li>
                  </ul>
                  <p class="small mt-2 mb-0">The resulting
                    <code>dist/index.php</code>
                    is what you deploy to Junction's
                    <strong>dist-php</strong>
                    drop tool.</p>
                </div>
              </div>
            </div>
          </div>
          <div class="alert alert-info mt-3 mb-0">
            <strong>Included automatically:</strong>
            php-dist is bundled with every ember-tribe installation — no
            separate install step needed.
          </div>
        </div>
      </div>

      <div
        class="step-card"
        data-step-name="Storylang Editor.js arc diagram component visualiser editor"
      >
        <div class="step-header" onclick="toggleStep(this)">
          <span class="step-badge"><i
              class="fa-solid fa-diagram-project"
            ></i></span>
          <span class="step-title">Storylang &amp; Editor.js</span>
          <i class="fa-solid fa-chevron-down step-chevron"></i>
        </div>
        <div class="step-body">
          <div class="row g-3">
            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6><strong><i class="fa-solid fa-circle-nodes me-1"></i>
                      Storylang</strong></h6>
                  <p class="small">Storylang analyses your Ember app and builds
                    an interactive arc diagram of every component, route,
                    service, helper, modifier, and type — plus the edges between
                    them.</p>
                  <p class="small mb-1">Generate the index from inside your
                    Ember application directory:</p>
                  <div class="command-block mb-2">
                    <button
                      class="btn btn-sm copy-btn-block"
                      onclick="copyCmd('node storylang', this)"
                      type="button"
                    >Copy</button>
                    <code>node storylang</code>
                  </div>
                  <p class="small mb-1">Then drop the viewer anywhere in your
                    app:</p>
                  <div class="command-block mb-0">
                    <button
                      class="btn btn-sm copy-btn-block"
                      onclick="copyCmd('<Storylang::Index />', this)"
                      type="button"
                    >Copy</button>
                    <code>&lt;Storylang::Index /&gt;</code>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6><strong><i class="fa-solid fa-pen-to-square me-1"></i>
                      Editor.js Viewer</strong></h6>
                  <p class="small">ember-tribe bundles an
                    <a
                      href="https://editorjs.io"
                      target="_blank"
                      rel="noopener noreferrer"
                    >Editor.js</a>
                    integration as a component. Use it wherever you need a
                    viewer for content edited using Editor.js in Junction:</p>
                  <div class="command-block mb-2">
                    <button
                      class="btn btn-sm copy-btn-block"
                      onclick="copyCmd('<Editorjs @jsondata={{@model.modules.body}} />', this)"
                      type="button"
                    >Copy</button>
                    <code>&lt;Editorjs @jsondata=\{{@model.modules.body}} /&gt;</code>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <ManualFooter />

  </div>
</div>

<ManualScripts />
