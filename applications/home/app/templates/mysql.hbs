<div class="tribe-manual">
  <ManualHeader />

  <ManualPageNav @activePage="mysql" />

  <div class="container pb-5">

    <div class="alert alert-dark mb-4">
      <div class="row align-items-center">
        <div class="col-md-8">
          <h5 class="mb-1"><i class="fa-solid fa-database me-2"></i>MySQL Tuning</h5>
          <p class="mb-0 small text-muted">Tune MySQL for higher loads via
            <code>my.cnf</code>.</p>
        </div>
        <div class="col-md-4 text-md-end mt-2 mt-md-0">
          <span class="badge bg-dark me-1">InnoDB</span>
          <span class="badge bg-dark">my.cnf</span>
        </div>
      </div>
    </div>

    <div class="steps-container mb-5">

      {{! ── my.cnf tuning ── }}
      <div
        class="step-card open"
        data-step-name="mysql my.cnf tuning innodb buffer pool connections performance"
      >
        <div class="step-header" onclick="toggleStep(this)">
          <span class="step-badge"><i class="fa-solid fa-sliders"></i></span>
          <span class="step-title">Tune MySQL with
            <code>my.cnf</code>
            <span
              class="badge bg-warning text-dark ms-2"
              style="font-size:0.65rem;vertical-align:middle;"
            >Recommended</span></span>
          <i class="fa-solid fa-chevron-down step-chevron"></i>
        </div>
        <div class="step-body">
          <p>The project ships a
            <code>config/mysql/my.cnf</code>
            that is bind-mounted into the MySQL container at
            <code>/etc/mysql/conf.d/my.cnf</code>. Edit it on the host; a
            container restart picks up the changes immediately.</p>

          <div class="alert alert-light mb-4">
            <strong>Rule of thumb:</strong>
            set
            <code>innodb_buffer_pool_size</code>
            to
            <strong>60–70 % of total RAM</strong>
            on a dedicated DB host, or
            <strong>25–40 %</strong>
            when MySQL shares the machine with the app. The default
            <code>1G</code>
            suits a 2–4 GB host.
          </div>

          <div class="row g-3 mb-4">

            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6 class="mb-2"><strong><i
                        class="fa-solid fa-memory me-1"
                      ></i><code>innodb_buffer_pool_size</code></strong></h6>
                  <p class="small text-muted mb-0">The single biggest lever for
                    InnoDB performance. Caches table data and indexes in RAM —
                    the more that fits here, the fewer disk reads MySQL needs.
                    Default:
                    <code>1G</code>.</p>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6 class="mb-2"><strong><i
                        class="fa-solid fa-layer-group me-1"
                      ></i><code>innodb_buffer_pool_instances</code></strong></h6>
                  <p class="small text-muted mb-0">Splits the buffer pool into
                    parallel chunks to reduce mutex contention under concurrent
                    load. Set to
                    <code>1</code>
                    per GB of buffer pool, up to
                    <code>8</code>. Default:
                    <code>4</code>.</p>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6 class="mb-2"><strong><i
                        class="fa-solid fa-file-circle-check me-1"
                      ></i><code>innodb_redo_log_capacity</code></strong></h6>
                  <p class="small text-muted mb-0">Total size of the InnoDB redo
                    log, used to absorb write bursts and speed crash recovery.
                    Larger values smooth out write-heavy workloads at the cost
                    of more disk space and longer recovery time. Default:
                    <code>256M</code>.</p>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6 class="mb-2"><strong><i
                        class="fa-solid fa-plug me-1"
                      ></i><code>max_connections</code></strong></h6>
                  <p class="small text-muted mb-0">Maximum simultaneous client
                    connections. Each open connection consumes RAM (roughly 1–2 MB
                    stack). Keep this tight — a high ceiling with a small buffer
                    pool causes OOM. Default:
                    <code>50</code>.</p>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6 class="mb-2"><strong><i
                        class="fa-solid fa-arrows-spin me-1"
                      ></i><code>thread_cache_size</code></strong></h6>
                  <p class="small text-muted mb-0">Idle threads kept alive so new
                    connections don't pay thread-creation cost. Set to roughly
                    <code>max_connections / 10</code>, minimum
                    <code>4</code>. Default:
                    <code>8</code>.</p>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6 class="mb-2"><strong><i
                        class="fa-solid fa-sort me-1"
                      ></i><code>sort_buffer_size</code></strong></h6>
                  <p class="small text-muted mb-0">Per-connection buffer used for
                    sorting results (ORDER BY / GROUP BY) that don't use an
                    index. Allocated per session, so keep it modest to avoid
                    runaway memory use under high concurrency. Default:
                    <code>256K</code>.</p>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6 class="mb-2"><strong><i
                        class="fa-solid fa-shuffle me-1"
                      ></i><code>read_rnd_buffer_size</code></strong></h6>
                  <p class="small text-muted mb-0">Per-connection buffer for
                    reading rows in sorted order after a filesort, e.g. when
                    resolving ORDER BY. Default:
                    <code>512K</code>.</p>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6 class="mb-2"><strong><i
                        class="fa-solid fa-table me-1"
                      ></i><code>tmp_table_size</code>
                    /
                    <code>max_heap_table_size</code></strong></h6>
                  <p class="small text-muted mb-0">Caps how large an in-memory
                    temporary table can grow (used for complex GROUP BY/ORDER BY
                    and some joins) before MySQL spills it to disk. Keep the two
                    in sync. Default:
                    <code>16M</code>
                    each.</p>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6 class="mb-2"><strong><i
                        class="fa-solid fa-hard-drive me-1"
                      ></i><code>innodb_flush_method</code></strong></h6>
                  <p class="small text-muted mb-0">Controls how InnoDB flushes
                    data and log files to disk.
                    <code>O_DIRECT</code>
                    bypasses the OS file cache to avoid double-buffering, since
                    InnoDB already caches data in the buffer pool.</p>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6 class="mb-2"><strong><i
                        class="fa-solid fa-bolt me-1"
                      ></i><code>innodb_flush_log_at_trx_commit</code></strong></h6>
                  <p class="small text-muted mb-0">Trades strict durability for
                    throughput.
                    <code>2</code>
                    flushes the log to the OS cache on every commit but only
                    syncs to disk once per second — fine for most apps, though a
                    host crash (not just a MySQL crash) could lose the last
                    second of transactions.</p>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6 class="mb-2"><strong><i
                        class="fa-solid fa-file-lines me-1"
                      ></i><code>slow_query_log</code>
                    /
                    <code>general_log</code></strong></h6>
                  <p class="small text-muted mb-0">Both disabled by default to
                    avoid the disk I/O overhead of logging every query. Enable
                    temporarily (set to
                    <code>1</code>) when debugging performance or query
                    behavior, then turn back off.</p>
                </div>
              </div>
            </div>

          </div>

          <p class="mb-2">Full
            <code>config/mysql/my.cnf</code>
            as shipped:</p>
          <div class="command-block mb-3">
            <button
              class="btn btn-sm copy-btn-block"
              onclick="copyCmd('[mysqld]\ninnodb_buffer_pool_size = 1G\ninnodb_buffer_pool_instances = 4\ninnodb_redo_log_capacity = 256M\n\nmax_connections = 50\nthread_cache_size = 8\nbind-address = 0.0.0.0\n\nsort_buffer_size = 256K\nread_rnd_buffer_size = 512K\ntmp_table_size = 16M\nmax_heap_table_size = 16M\n\nslow_query_log = 0\ngeneral_log = 0\n\ninnodb_flush_method = O_DIRECT\ninnodb_flush_log_at_trx_commit = 2', this)"
              type="button"
            >Copy</button>
            <code><span class="comment">[mysqld]</span><br />innodb_buffer_pool_size
              = 1G<br />innodb_buffer_pool_instances = 4<br />innodb_redo_log_capacity
              = 256M<br /><br />max_connections = 50<br />thread_cache_size =
              8<br />bind-address = 0.0.0.0<br /><br />sort_buffer_size =
              256K<br />read_rnd_buffer_size = 512K<br />tmp_table_size =
              16M<br />max_heap_table_size = 16M<br /><br />slow_query_log =
              0<br />general_log = 0<br /><br />innodb_flush_method =
              O_DIRECT<br />innodb_flush_log_at_trx_commit = 2</code>
          </div>

          <p class="mb-1">After editing, restart the container to apply:</p>
          <div class="command-block mb-0">
            <button
              class="btn btn-sm copy-btn-block"
              onclick="copyCmd('docker compose restart mysql', this)"
              type="button"
            >Copy</button>
            <code>docker compose restart mysql</code>
          </div>
        </div>
      </div>

    </div>

    {{! ── Quick Reference ── }}
    <div class="section-divider mb-4">
      <span class="section-label">QUICK REFERENCE</span>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-md-12">
        <div class="alert alert-dark mb-0">
          <h5 class="mb-2">Key my.cnf Settings</h5>
          <p class="mb-0">
            <strong>Buffer pool:</strong>
            <code>innodb_buffer_pool_size = 1G</code><br />
            <strong>Instances:</strong>
            <code>innodb_buffer_pool_instances = 4</code><br />
            <strong>Redo log capacity:</strong>
            <code>innodb_redo_log_capacity = 256M</code><br />
            <strong>Connections:</strong>
            <code>max_connections = 50</code><br />
            <strong>Thread cache:</strong>
            <code>thread_cache_size = 8</code><br />
            <strong>Sort buffer:</strong>
            <code>sort_buffer_size = 256K</code><br />
            <strong>Read random buffer:</strong>
            <code>read_rnd_buffer_size = 512K</code><br />
            <strong>Temp table size:</strong>
            <code>tmp_table_size = 16M</code><br />
            <strong>Max heap table size:</strong>
            <code>max_heap_table_size = 16M</code><br />
            <strong>Flush method:</strong>
            <code>innodb_flush_method = O_DIRECT</code><br />
            <strong>Flush log at trx commit:</strong>
            <code>innodb_flush_log_at_trx_commit = 2</code>
          </p>
        </div>
      </div>
    </div>

    <ManualFooter />

  </div>
</div>

<ManualScripts />
