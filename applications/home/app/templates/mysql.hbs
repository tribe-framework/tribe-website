<div class="tribe-manual">
  <ManualHeader />

  <ManualPageNav @activePage="mysql" />

  <div class="container pb-5">

    <div class="alert alert-dark mb-4">
      <div class="row align-items-center">
        <div class="col-md-8">
          <h5 class="mb-1"><i class="fa-solid fa-database me-2"></i>MySQL Tuning
            &amp; Migration</h5>
          <p class="mb-0 small text-muted">Tune MySQL for higher loads via
            <code>my.cnf</code>
            and migrate existing named-volume data into the project folder so
            it's easy to snapshot, back up, and transport.</p>
        </div>
        <div class="col-md-4 text-md-end mt-2 mt-md-0">
          <span class="badge bg-dark me-1">InnoDB</span>
          <span class="badge bg-dark me-1">my.cnf</span>
          <span class="badge bg-dark me-1">bind-mount</span>
          <span class="badge bg-dark">migration</span>
        </div>
      </div>
    </div>

    <div class="steps-container mb-5">

      {{! ── my.cnf tuning ── }}
      <div
        class="step-card open"
        data-step-name="mysql my.cnf tuning innodb buffer pool connections performance"
      >
        <div class="step-header" onclick="toggleStep(this)">
          <span class="step-badge"><i class="fa-solid fa-sliders"></i></span>
          <span class="step-title">Tune MySQL with
            <code>my.cnf</code>
            <span
              class="badge bg-warning text-dark ms-2"
              style="font-size:0.65rem;vertical-align:middle;"
            >Recommended</span></span>
          <i class="fa-solid fa-chevron-down step-chevron"></i>
        </div>
        <div class="step-body">
          <p>The project ships a
            <code>config/mysql/my.cnf</code>
            that is bind-mounted into the MySQL container at
            <code>/etc/mysql/conf.d/my.cnf</code>. Edit it on the host; a
            container restart picks up the changes immediately.</p>

          <div class="alert alert-light mb-4">
            <strong>Rule of thumb:</strong>
            set
            <code>innodb_buffer_pool_size</code>
            to
            <strong>60–70 % of total RAM</strong>
            on a dedicated DB host, or
            <strong>25–40 %</strong>
            when MySQL shares the machine with the app. The default
            <code>2G</code>
            suits a 4–8 GB host.
          </div>

          <div class="row g-3 mb-4">

            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6 class="mb-2"><strong><i
                        class="fa-solid fa-memory me-1"
                      ></i><code>innodb_buffer_pool_size</code></strong></h6>
                  <p class="small text-muted mb-0">The single biggest lever for
                    InnoDB performance. Caches table data and indexes in RAM —
                    the more that fits here, the fewer disk reads MySQL needs.
                    Default:
                    <code>2G</code>.</p>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6 class="mb-2"><strong><i
                        class="fa-solid fa-layer-group me-1"
                      ></i><code>innodb_buffer_pool_instances</code></strong></h6>
                  <p class="small text-muted mb-0">Splits the buffer pool into
                    parallel chunks to reduce mutex contention under concurrent
                    load. Set to
                    <code>1</code>
                    per GB of buffer pool, up to
                    <code>8</code>. Default:
                    <code>2</code>.</p>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6 class="mb-2"><strong><i
                        class="fa-solid fa-plug me-1"
                      ></i><code>max_connections</code></strong></h6>
                  <p class="small text-muted mb-0">Maximum simultaneous client
                    connections. Each open connection consumes RAM (roughly 1–2 MB
                    stack). Keep this tight — a high ceiling with a small buffer
                    pool causes OOM. Default:
                    <code>50</code>.</p>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6 class="mb-2"><strong><i
                        class="fa-solid fa-arrows-spin me-1"
                      ></i><code>thread_cache_size</code></strong></h6>
                  <p class="small text-muted mb-0">Idle threads kept alive so new
                    connections don't pay thread-creation cost. Set to roughly
                    <code>max_connections / 10</code>, minimum
                    <code>4</code>. Default:
                    <code>4</code>.</p>
                </div>
              </div>
            </div>

          </div>

          <p class="mb-2">Full
            <code>config/mysql/my.cnf</code>
            as shipped:</p>
          <div class="command-block mb-3">
            <button
              class="btn btn-sm copy-btn-block"
              onclick="copyCmd('[mysqld]\ninnodb_buffer_pool_size = 2G\ninnodb_buffer_pool_instances = 2\n\n# Connections\nmax_connections = 50\nthread_cache_size = 4\n\n# Network binding\nbind-address = 0.0.0.0', this)"
              type="button"
            >Copy</button>
            <code><span class="comment">[mysqld]</span><br />innodb_buffer_pool_size
              = 2G<br />innodb_buffer_pool_instances = 2<br /><br /><span
                class="comment"
              ># Connections</span><br />max_connections = 50<br />thread_cache_size
              = 4<br /><br /><span class="comment"># Network
                binding</span><br />bind-address = 0.0.0.0</code>
          </div>

          <p class="mb-1">After editing, restart the container to apply:</p>
          <div class="command-block mb-0">
            <button
              class="btn btn-sm copy-btn-block"
              onclick="copyCmd('docker compose restart mysql', this)"
              type="button"
            >Copy</button>
            <code>docker compose restart mysql</code>
          </div>
        </div>
      </div>

      {{! ── Named volume → bind mount migration ── }}
      <div
        class="step-card"
        data-step-name="mysql migrate volume bind mount uploads docker named volume old instance"
      >
        <div class="step-header" onclick="toggleStep(this)">
          <span class="step-badge"><i class="fa-solid fa-arrow-right-arrow-left"></i></span>
          <span class="step-title">Migrate from a Named Volume
            <span
              class="badge bg-warning text-dark ms-2"
              style="font-size:0.65rem;vertical-align:middle;"
            >Existing instances</span></span>
          <i class="fa-solid fa-chevron-down step-chevron"></i>
        </div>
        <div class="step-body">
          <p>Older deployments stored MySQL data in a Docker named volume
            (<code>PROJECT_NAME_mysql_data</code>). The current setup uses a
            bind-mount at
            <code>./uploads/mysql</code>
            so all project data lives in one folder — easier to snapshot, back
            up, and move between hosts.</p>

          <div class="alert alert-light mb-4">
            <strong>What the script does:</strong>
            stops MySQL cleanly, copies everything from the named volume into
            <code>./uploads/mysql</code>
            via a temporary Alpine container, patches
            <code>docker-compose.yml</code>
            to switch the volume reference, then restarts and health-checks
            MySQL. The original named volume is
            <strong>not deleted</strong>
            — you remove it manually once you've verified the migration.
          </div>

          <div class="steps-container mb-0">

            {{! Step 1 }}
            <div class="step-card">
              <div class="step-header" onclick="toggleStep(this)">
                <span class="step-badge">1</span>
                <span class="step-title">Run from the Project Root</span>
                <i class="fa-solid fa-chevron-down step-chevron"></i>
              </div>
              <div class="step-body">
                <p>
                  <code>PROJECT_NAME</code>
                  is read from your
                  <code>.env</code>
                  file automatically. Docker must be running.</p>
                <div class="command-block mb-0">
                  <button
                    class="btn btn-sm copy-btn-block"
                    onclick="copyCmd('cd /path/to/your/project\nbash config/tribe/migrate-mysql-volume.sh', this)"
                    type="button"
                  >Copy</button>
                  <code>cd /path/to/your/project<br />bash
                    config/tribe/migrate-mysql-volume.sh</code>
                </div>
              </div>
            </div>

            {{! Step 2 }}
            <div class="step-card">
              <div class="step-header" onclick="toggleStep(this)">
                <span class="step-badge">2</span>
                <span class="step-title">Verify MySQL is Healthy</span>
                <i class="fa-solid fa-chevron-down step-chevron"></i>
              </div>
              <div class="step-body">
                <p>The script waits for
                  <code>mysqladmin ping</code>
                  to succeed before finishing. Confirm yourself with:</p>
                <div class="command-block mb-0">
                  <button
                    class="btn btn-sm copy-btn-block"
                    onclick="copyCmd('docker compose exec mysql mysqladmin ping -h localhost', this)"
                    type="button"
                  >Copy</button>
                  <code>docker compose exec mysql mysqladmin ping -h
                    localhost</code>
                </div>
              </div>
            </div>

            {{! Step 3 }}
            <div class="step-card">
              <div class="step-header" onclick="toggleStep(this)">
                <span class="step-badge">3</span>
                <span class="step-title">Remove the Old Named Volume</span>
                <i class="fa-solid fa-chevron-down step-chevron"></i>
              </div>
              <div class="step-body">
                <p>Once you're satisfied everything works, delete the now-unused
                  named volume to reclaim disk space. Replace
                  <code>PROJECT_NAME</code>
                  with the value from your
                  <code>.env</code>.</p>
                <div class="command-block mb-0">
                  <button
                    class="btn btn-sm copy-btn-block"
                    onclick="copyCmd('docker volume rm PROJECT_NAME_mysql_data', this)"
                    type="button"
                  >Copy</button>
                  <code>docker volume rm PROJECT_NAME_mysql_data</code>
                </div>
              </div>
            </div>

          </div>{{! end inner steps-container }}

          <div class="row g-3 mt-3">
            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6 class="mb-2"><strong><i
                        class="fa-solid fa-triangle-exclamation me-1"
                      ></i>Non-empty Target Aborts</strong></h6>
                  <p class="small text-muted mb-0">If
                    <code>./uploads/mysql</code>
                    already exists and is non-empty the script exits without
                    touching anything. Clear or rename it first to proceed.</p>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="card method-item h-100">
                <div class="card-body">
                  <h6 class="mb-2"><strong><i
                        class="fa-solid fa-file-pen me-1"
                      ></i>Backup Kept</strong></h6>
                  <p class="small text-muted mb-0">The script saves your original
                    <code>docker-compose.yml</code>
                    as
                    <code>docker-compose.yml.bak</code>
                    before patching. Restore it with
                    <code>mv docker-compose.yml.bak docker-compose.yml</code>
                    if needed.</p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>

    {{! ── Quick Reference ── }}
    <div class="section-divider mb-4">
      <span class="section-label">QUICK REFERENCE</span>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-md-6">
        <div class="alert alert-dark mb-0">
          <h5 class="mb-2">Key my.cnf Settings</h5>
          <p class="mb-0">
            <strong>Buffer pool:</strong>
            <code>innodb_buffer_pool_size = 2G</code><br />
            <strong>Instances:</strong>
            <code>innodb_buffer_pool_instances = 2</code><br />
            <strong>Connections:</strong>
            <code>max_connections = 50</code><br />
            <strong>Thread cache:</strong>
            <code>thread_cache_size = 4</code>
          </p>
        </div>
      </div>
      <div class="col-md-6">
        <div class="alert alert-dark mb-0">
          <h5 class="mb-2">Migration Script</h5>
          <p class="mb-0">
            <strong>Run:</strong>
            <code>bash config/tribe/migrate-mysql-volume.sh</code><br />
            <strong>Requires:</strong>
            <code>PROJECT_NAME</code>
            in
            <code>.env</code>, Docker running<br />
            <strong>After:</strong>
            <code>docker volume rm PROJECT_NAME_mysql_data</code>
          </p>
        </div>
      </div>
    </div>

    <ManualFooter />

  </div>
</div>

<ManualScripts />
