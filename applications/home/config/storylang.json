{
  "components": [
    {
      "name": "manual-footer"
    },
    {
      "name": "manual-header"
    },
    {
      "name": "manual-page-nav",
      "inherited_args": [{ "route": "var" }]
    },
    {
      "name": "manual-scripts"
    },
    {
      "name": "welcome-flame"
    }
  ],
  "routes": [
    {
      "name": "application",
      "actions": ["did-transition", "will-transition"],
      "services": ["types"],
      "components": ["basic-dropdown-wormhole"]
    },
    {
      "name": "backend",
      "components": ["manual-header", "manual-page-nav", "manual-footer", "manual-scripts"]
    },
    {
      "name": "frontend",
      "components": ["manual-header", "manual-page-nav", "manual-footer", "manual-scripts"]
    },
    {
      "name": "index",
      "components": ["manual-header", "manual-page-nav", "link-to", "manual-footer", "manual-scripts"]
    },
    {
      "name": "prerequisites",
      "components": ["manual-header", "manual-page-nav", "manual-footer", "manual-scripts"]
    }
  ],
  "services": [
    {
      "name": "cookies",
      "tracked_vars": [{ "days": "int" }],
      "actions": ["set-cookie", "get-cookie", "erase-cookie"]
    },
    {
      "name": "types",
      "tracked_vars": [{ "json": "string" }],
      "actions": ["fetch-again"],
      "services": ["store"]
    }
  ],
  "modifiers": [{ "name": "did-insert" }, { "name": "ripple" }]
}
